{
  "rule_set_id": "rs_01_clean",
  "description": "Standard recreational quadcopter — all rules consistent (expected: PASS)",
  "vehicle_class": "recreational_quadcopter",
  "rules": {
    "max_altitude": {
      "rule_name": "§1 FAA Part 107 Altitude Ceiling",
      "max_altitude_m": 120,
      "enabled": true
    },
    "min_altitude": {
      "rule_name": "§2 Minimum Safe Operating Altitude",
      "min_altitude_m": 10,
      "is_absolute": false,
      "enabled": true
    },
    "emergency_descent": {
      "rule_name": "§3 Emergency Descent to Landing Pad",
      "descent_target_altitude_m": 5,
      "overrides_min_altitude": false,
      "enabled": true
    },
    "signal_loss_hold": {
      "rule_name": "§4 Signal Loss — Hold Position",
      "trigger": "signal_loss",
      "action": "HOLD",
      "enabled": false
    },
    "signal_loss_rth": {
      "rule_name": "§5 Signal Loss — Return to Home",
      "trigger": "signal_loss",
      "action": "RTH",
      "enabled": true
    },
    "rth_battery_threshold": {
      "rule_name": "§6 Low Battery RTH Trigger",
      "trigger_battery_pct": 20,
      "enabled": true
    }
  }
}
